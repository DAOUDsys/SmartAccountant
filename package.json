{
  "name": "finance-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade AI accounting application foundation.",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:mobile",
    "dev:backend": "npm run start:dev --workspace @finance-ai/backend",
    "dev:mobile": "npm run start --workspace @finance-ai/mobile",
    "build": "npm-run-all build:shared-types build:utils build:config build:ui build:backend typecheck:mobile",
    "build:shared-types": "npm run build --workspace @finance-ai/shared-types",
    "build:utils": "npm run build --workspace @finance-ai/utils",
    "build:config": "npm run build --workspace @finance-ai/config",
    "build:ui": "npm run build --workspace @finance-ai/ui",
    "build:backend": "npm run build --workspace @finance-ai/backend",
    "typecheck": "npm-run-all build:shared-types typecheck:utils typecheck:config typecheck:ui typecheck:backend typecheck:mobile",
    "typecheck:utils": "npm run typecheck --workspace @finance-ai/utils",
    "typecheck:config": "npm run typecheck --workspace @finance-ai/config",
    "typecheck:ui": "npm run typecheck --workspace @finance-ai/ui",
    "typecheck:backend": "npm run typecheck --workspace @finance-ai/backend",
    "typecheck:mobile": "npm run typecheck --workspace @finance-ai/mobile",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:validate": "npm run prisma:validate --workspace @finance-ai/backend",
    "prisma:generate": "npm run prisma:generate --workspace @finance-ai/backend",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "expo-asset": "~11.0.5",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.10"
  }
}
